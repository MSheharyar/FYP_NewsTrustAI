# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real secrets.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Set to "false" only in local/dev environments (guarded by APP_ENV check).
REQUIRE_AUTH=true

# "local", "dev", or "production". Controls auth safety guard.
APP_ENV=production

# ── Firebase ─────────────────────────────────────────────────────────────────
# Paste the full JSON of your Firebase service account key (from Firebase Console
# → Project Settings → Service Accounts → Generate new private key).
# Alternative: set GOOGLE_APPLICATION_CREDENTIALS to the path of the JSON file.
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── External APIs ─────────────────────────────────────────────────────────────
# HuggingFace Inference API token — required for Urdu BERT classification.
# Get one at https://huggingface.co/settings/tokens
HF_API_TOKEN=

# Google Fact Check Tools API key — used as a fallback verifier.
# Get one at https://console.cloud.google.com → APIs & Services → Fact Check Tools API
GOOGLE_FACTCHECK_API_KEY=

# Gemini API key — required for the /chat endpoint.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Model selection (optional — defaults shown) ────────────────────────────────
# BERT_MODEL_NAME=mrm8488/bert-tiny-finetuned-fake-news-detection
# URDU_MODEL_ID=ikomil/bert-urdu-fake-news
# NLI_MODEL_NAME=cross-encoder/nli-MiniLM2-L6-H768
# EMBED_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ── Paths (optional — defaults relative to package root) ──────────────────────
# DATABASE_FILE=/absolute/path/to/global_news_db.json
# MODEL_DIR=/absolute/path/to/model

# ── Tuning (optional — safe to leave as defaults) ─────────────────────────────
# LOG_LEVEL=INFO
# VERIFY_THRESHOLD=75
# CORS_ORIGINS=*
# DEBUG=false
